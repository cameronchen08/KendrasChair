# GitHub fine-grained PAT with "Contents: Read & Write" and "Pull requests: Read & Write"
# on the KendrasChair repo. Set these in Vercel → Project Settings → Environment Variables.
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=KendrasChair
GITHUB_BASE_BRANCH=master

# Admin password — validated server-side on every PR submission.
# Must match whatever password Kendra enters in the admin panel.
ADMIN_PASSWORD=your_admin_password_here
